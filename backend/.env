# Portfolio Backend Environment Variables

# Django Settings
SECRET_KEY=your-super-secret-key-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database Configuration
DATABASE_URL=sqlite:///db.sqlite3
# For PostgreSQL: DATABASE_URL=postgresql://username:password@localhost:5432/portfolio_db

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
CORS_ALLOW_CREDENTIALS=True

# Email Configuration (for contact form)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# For production with SES:
# EMAIL_BACKEND=django_ses.SESBackend
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_SES_REGION_NAME=us-east-1

# Admin Configuration
ADMIN_EMAIL=bhautikgosai4318@gmail.com
ADMIN_NAME=Bhautik Gauswami

# Media Files
MEDIA_ROOT=media/
MEDIA_URL=/media/

# Static Files
STATIC_ROOT=staticfiles/
STATIC_URL=/static/
